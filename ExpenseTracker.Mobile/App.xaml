<?xml version = "1.0" encoding = "UTF-8" ?>
<Application
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="ExpenseTracker.Mobile.App">
    <Application.Resources>
        <ResourceDictionary>
            <Color x:Key="PageBackgroundColor">#F5F5F5</Color>
            <Color x:Key="PrimaryColor">#2196F3</Color>
            <Color x:Key="SecondaryColor">#FFC107</Color>
            <Color x:Key="DangerColor">#F44336</Color>
            <Color x:Key="SuccessColor">#4CAF50</Color>
            <Color x:Key="TextColor">#212121</Color>
            <Color x:Key="LightTextColor">#757575</Color>
            <Color x:Key="CardBackgroundColor">#FFFFFF</Color>

            <Style TargetType="Page">
                <Setter Property="BackgroundColor" Value="{StaticResource PageBackgroundColor}" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
