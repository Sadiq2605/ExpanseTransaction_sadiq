<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="ExpenseTracker.Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <TabBar>
        <ShellContent
            Title="Dashboard"
            Icon="dashboard.png"
            Route="dashboard" />

        <ShellContent
            Title="Add Expense"
            Icon="add.png"
            Route="add" />

        <ShellContent
            Title="Expenses"
            Icon="list.png"
            Route="expenses" />

        <ShellContent
            Title="Reports"
            Icon="chart.png"
            Route="reports" />
    </TabBar>

</Shell>
